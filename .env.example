# =============================================================================
# void --news — environment variables
# Copy to .env (NOT checked in) and fill in values. For deploy, set the same
# names as GitHub Actions secrets in repo settings → Secrets and variables.
# =============================================================================

# ---- Supabase ---------------------------------------------------------------
# Used by both the Python pipeline and the Next.js frontend.
SUPABASE_URL=
SUPABASE_KEY=                              # pipeline scripts use this; same value as SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=                 # frontend server-side (admin, ig render)
NEXT_PUBLIC_SUPABASE_URL=                  # frontend client-side (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=             # frontend client-side (public anon)

# ---- LLM --------------------------------------------------------------------
ANTHROPIC_API_KEY=                         # Sonnet 4.6 — daily brief + captions + summaries
GEMINI_API_KEY=                            # fallback only; not required at runtime

# ---- Instagram automation ---------------------------------------------------
# Long-lived 60-day token, auto-refreshed weekly by ig-token-refresh.yml.
INSTAGRAM_GRAPH_TOKEN=
# Numeric IG Business account id (from Meta dashboard).
INSTAGRAM_USER_ID=
# Meta app credentials. Required for the token-refresh cron.
META_APP_ID=
META_APP_SECRET=
# Used by the CF Pages Function /api/ig/webhook for sig + handshake.
META_WEBHOOK_VERIFY_TOKEN=                 # any random string you pick
# Graph API version override (default v21.0).
# META_GRAPH_API_VERSION=v21.0

# GitHub PAT scoped to repo:secrets only, used by ig-token-refresh.yml to
# write the refreshed token back into Actions secrets.
IG_SECRET_WRITE_TOKEN=

# ---- Bluesky cross-post -----------------------------------------------------
BLUESKY_HANDLE=                            # e.g. void.news.bsky.social or your verified domain
BLUESKY_APP_PASSWORD=                      # bsky.app/settings → app passwords (not your main pw)

# ---- Admin panel (basic auth on /admin/ig and /admin/ig/inbox) ---------------
IG_ADMIN_USER=
IG_ADMIN_PASSWORD=

# ---- Renderer dev base url (used by ig_capture.py) --------------------------
# Default http://localhost:3000. Set if you run the dev server on a different port.
# RENDER_BASE_URL=http://localhost:3000

# ---- Existing pipeline toggles (see CLAUDE.md for context) ------------------
DISABLE_AUDIO=1
NEXT_PUBLIC_DISABLE_AUDIO=1
DISABLE_GEMINI_REASONING=1
DISABLE_EDITORIAL_TRIAGE=1
