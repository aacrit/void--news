{
  "name": "void --news",
  "short_name": "void--news",
  "description": "Free per-article bias analysis across 1,016 sources. Six axes. No paywall. No algorithm.",
  "id": "/void--news/",
  "start_url": "/void--news/",
  "scope": "/void--news/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#1C1A17",
  "theme_color": "#1C1A17",
  "categories": ["news", "education"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "shortcuts": [
    {
      "name": "Today's feed",
      "short_name": "Feed",
      "url": "/void--news/",
      "icons": [{ "src": "/void--news/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/void--news/",
    "method": "GET",
    "params": {
      "url": "shared_url"
    }
  },
  "icons": [
    {
      "src": "/void--news/icon.svg",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    },
    {
      "src": "/void--news/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/void--news/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/void--news/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
